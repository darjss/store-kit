---
import { commerce } from '@store-kit/commerce'
import { formatMnt } from '@store-kit/storefront/format'
import ProductImage from '~/components/ProductImage.astro'
import { selectHomeProducts } from '~/home-products'
import Layout from '~/layouts/Layout.astro'
import { toPublicImage } from '~/public-image'

const result = await commerce.catalog.listProducts({ limit: 24 })
if (result.status === 'error') throw new Error('Catalog could not be loaded.')
const products = result.value.items.map(product => ({
  ...product,
  images: product.images.map(toPublicImage),
}))
const [tangzu, keyx, prx] = selectHomeProducts(products)
const featuredSlugs = new Set([tangzu.slug, keyx.slug, prx.slug])
const laterProducts = products.filter(product => !featuredSlugs.has(product.slug)).slice(0, 3)
const imageOf = (product: (typeof products)[number]) => product.images[0]
const priceOf = (product: (typeof products)[number]) => product.variants[0]?.priceMnt ?? 0
const categories = [
  { label: 'IEM', href: '/products?category=in-ear-monitors', note: 'Утастай, тайзны нарийвчлал' },
  { label: 'DAC', href: '/products?category=portable-audio', note: 'Утаснаас цэвэр гаралт' },
  { label: 'ACCESSORIES', href: '/products?category=eartips', note: 'Каталог шинэчлэгдэж байна' },
]
---

<Layout title="Plugged · Portable audio, Ulaanbaatar" publicPage>
  <main id="main-content" tabindex="-1" class="bg-ink xl:ml-36">
    <section class="relative min-h-[930px] overflow-clip border-b-4 border-paper-clean bg-petrol text-paper max-md:min-h-[1450px]" aria-labelledby="hero-title">
      <div class="absolute -inset-x-[7%] top-4 bottom-5 -rotate-[1.4deg] bg-petrol [background-image:url('/textures/xerox-dust.webp')] [background-blend-mode:soft-light] max-md:inset-x-0 max-md:top-0 max-md:bottom-0 max-md:rotate-0"></div>
      <div class="pointer-events-none absolute inset-0 opacity-45 [background:url('/textures/registration-marks.webp')_right_2rem_top_2rem/5rem_no-repeat]" aria-hidden="true"></div>

      <div class="absolute top-[10%] left-[5%] z-10 flex -rotate-2 flex-col items-start gap-1 max-md:top-10 max-md:left-4">
        <h1 id="hero-title" class="contents">
          <span data-paper class="texture-paper block px-[clamp(0.8rem,2vw,1.5rem)] py-1 font-body text-[clamp(3.4rem,7vw,6rem)] leading-[0.95] font-black tracking-[-0.03em] whitespace-nowrap text-ink shadow-[0.35rem_0.45rem_0_var(--color-ink)] max-[340px]:text-[2.8rem]">СОНС.</span>
          <span data-paper class="texture-paper ml-[7%] block -rotate-1 px-[clamp(0.8rem,2vw,1.5rem)] py-1 font-body text-[clamp(3.4rem,7vw,6rem)] leading-[0.95] font-black tracking-[-0.03em] whitespace-nowrap text-ink shadow-[0.35rem_0.45rem_0_var(--color-ink)] max-[340px]:text-[2.8rem]">ТААРУУЛ.</span>
          <span data-paper class="texture-paper ml-[2%] block rotate-1 px-[clamp(0.8rem,2vw,1.5rem)] py-1 font-body text-[clamp(3.4rem,7vw,6rem)] leading-[0.95] font-black tracking-[-0.03em] whitespace-nowrap text-ink shadow-[0.35rem_0.45rem_0_var(--color-ink)] max-[340px]:text-[2.8rem]">АВ.</span>
        </h1>
        <p class="mt-5 ml-3 max-w-64 font-extrabold text-paper">Утастай сонсгол. Цэвэр гаралт.</p>
      </div>

      <img data-chain class="pointer-events-none absolute top-[4%] right-[2%] z-2 h-auto w-[72%] object-contain [filter:drop-shadow(0_0.65rem_0.45rem_rgb(0_0_0/0.58))] max-md:top-[24%] max-md:right-0 max-md:w-full" src="/objects/iem-dac-listening-chain.png" width="1536" height="1024" alt="Улаан Tangzu IEM-ийн сүлжмэл кабель Truthear KEYX DAC-д залгаастай" />

      <article class="absolute top-[43%] right-[-2%] z-6 w-[59%] max-md:top-[48%] max-md:right-3 max-md:w-[calc(100%-1.5rem)]">
        <div data-strip class="texture-paper grid min-h-24 -rotate-1 grid-cols-[minmax(0,1fr)_auto_auto] items-center gap-5 px-7 py-4 text-ink shadow-[0.4rem_0.45rem_0_rgb(0_0_0/0.7)] [clip-path:polygon(1%_2%,100%_0,99%_94%,0_100%)] max-md:min-h-28 max-md:grid-cols-[1fr_auto] max-md:gap-2 max-md:px-4">
          <h2 class="font-body text-[clamp(1.1rem,2vw,1.65rem)] leading-none font-black tracking-[-0.02em] uppercase max-md:col-span-2">{tangzu.name}</h2>
          <strong class="text-[clamp(1.4rem,2.3vw,2rem)] tabular-nums">{formatMnt(priceOf(tangzu))}</strong>
          <a class="pressable text-cyan-deep font-black no-underline" href={`/products/${tangzu.slug}`}>СОНГОХ →</a>
        </div>
      </article>

      <article class="absolute right-[-1%] bottom-[8%] z-6 w-[51%] max-md:top-[72%] max-md:right-3 max-md:bottom-auto max-md:w-[calc(100%-1.5rem)]">
        <div data-strip class="texture-paper grid min-h-24 rotate-1 grid-cols-[minmax(0,1fr)_auto_auto] items-center gap-5 px-7 py-4 text-ink shadow-[0.4rem_0.45rem_0_rgb(0_0_0/0.7)] [clip-path:polygon(0_3%,100%_0,98%_100%,1%_95%)] max-md:min-h-28 max-md:grid-cols-[1fr_auto] max-md:gap-2 max-md:px-4">
          <h2 class="font-body text-[clamp(1.1rem,2vw,1.65rem)] leading-none font-black uppercase max-md:col-span-2">{keyx.name}</h2>
          <strong class="text-[clamp(1.4rem,2.3vw,2rem)] tabular-nums">{formatMnt(priceOf(keyx))}</strong>
          <a class="pressable text-cyan-deep font-black no-underline" href={`/products/${keyx.slug}`}>СОНГОХ →</a>
        </div>
      </article>
    </section>

    <section class="relative overflow-hidden border-b-4 border-ink bg-paper py-[clamp(4rem,8vw,8rem)] text-ink [background-image:url('/textures/paper-grain.avif')] [background-blend-mode:multiply]" aria-labelledby="second-listen">
      <div class="mx-auto max-w-[86rem] px-gutter">
        <div class="grid grid-cols-[0.8fr_1.2fr] items-end gap-8 max-md:block">
          <h2 id="second-listen" class="font-body text-[clamp(2.7rem,6vw,5.6rem)] leading-[0.9] font-black tracking-[-0.035em] text-balance">ӨӨР ЧИМЭЭ.<br /><span class="text-cyan-deep">ИЖИЛ СИГНАЛ.</span></h2>
          <p class="ml-auto max-w-120 border-t-4 border-ink pt-4 font-extrabold max-md:mt-6">Planar нарийвчлалаас өдөр тутмын IEM хүртэл. Каталогийн бодит бараанаас сонгоно.</p>
        </div>
        <article class="mt-12 grid grid-cols-[minmax(16rem,0.85fr)_1.15fr] items-center max-md:grid-cols-1">
          <a class="relative z-2 block" href={`/products/${prx.slug}`}>
            {imageOf(prx) && <ProductImage class="aspect-square w-full -rotate-3 object-contain mix-blend-multiply transition-transform duration-200 ease-paper hover:rotate-0 motion-reduce:transition-none" image={imageOf(prx)!} layout="wall" />}
          </a>
          <div data-strip class="paper-stack relative z-3 -ml-12 grid min-h-32 grid-cols-[1fr_auto_auto] items-center gap-6 px-8 py-5 [clip-path:polygon(1%_0,100%_4%,99%_100%,0_94%)] max-md:-mt-6 max-md:ml-0 max-md:grid-cols-[1fr_auto] max-md:px-5">
            <h3 class="font-body text-[clamp(2rem,4vw,4rem)] leading-[0.9] font-black uppercase max-md:col-span-2">{prx.name}</h3>
            <strong class="text-2xl tabular-nums">{formatMnt(priceOf(prx))}</strong>
            <a class="pressable text-cyan-deep font-black no-underline" href={`/products/${prx.slug}`}>СОНГОХ →</a>
          </div>
        </article>
      </div>
    </section>

    {laterProducts.length > 0 && <section class="bg-paper-clean text-ink" aria-labelledby="more-title">
      <div class="flex items-end justify-between gap-6 border-b-4 border-ink px-gutter py-8 max-md:block">
        <h2 id="more-title" class="font-body text-[clamp(2.5rem,6vw,5rem)] leading-[0.9] font-black tracking-[-0.03em]">ДАРААГИЙН СОНСГОЛ</h2>
        <a class="pressable shrink-0 font-black" href="/products">БҮХ БАРАА →</a>
      </div>
      <div class="divide-y-4 divide-ink">
        {laterProducts.map((product, index) => <article class="group grid grid-cols-[5rem_minmax(12rem,0.55fr)_1fr_auto] items-center gap-6 px-gutter py-5 max-md:grid-cols-[2.5rem_5.5rem_1fr] max-md:gap-3">
          <span class="font-display text-6xl leading-none text-cyan-deep max-md:text-4xl">0{index + 1}</span>
          {imageOf(product) && <ProductImage class="aspect-[4/3] w-full object-contain mix-blend-multiply transition-transform duration-200 ease-paper group-hover:-rotate-2 group-hover:scale-[1.03] motion-reduce:transition-none max-md:aspect-square" image={imageOf(product)!} layout="card" />}
          <div><h3 class="font-body text-[clamp(1.25rem,2.4vw,2rem)] leading-none font-black"><a class="no-underline" href={`/products/${product.slug}`}>{product.name}</a></h3><p class="mt-2 max-w-120 max-md:hidden">{product.shortDescription}</p></div>
          <div class="flex items-center gap-8 max-md:col-[2/4] max-md:justify-between"><strong class="text-xl tabular-nums">{formatMnt(priceOf(product))}</strong><a class="pressable text-cyan-deep font-black no-underline" href={`/products/${product.slug}`}>СОНГОХ →</a></div>
        </article>)}
      </div>
    </section>}

    <section class="grid grid-cols-3 border-y-4 border-paper-clean bg-ink text-paper max-md:grid-cols-1" aria-label="Барааны ангилал">
      {categories.map((category, index) => <a class="pressable flex min-h-60 flex-col justify-between border-r-4 border-paper-clean p-5 no-underline last:border-r-0 hover:text-cyan max-md:min-h-40 max-md:border-r-0 max-md:border-b-4 max-md:last:border-b-0" href={category.href}>
        <span class="font-body text-[clamp(2.5rem,6vw,5.5rem)] leading-[0.85] font-black tracking-[-0.03em]">{category.label}</span>
        <span class="flex items-end justify-between gap-4"><strong class="max-w-60">{category.note}</strong><b class="text-3xl text-cyan">0{index + 1} ↗</b></span>
      </a>)}
    </section>
  </main>
  <script>
    if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const easing = 'cubic-bezier(0.16, 1, 0.3, 1)'
      document.querySelectorAll('[data-paper]').forEach((element, index) =>
        element.animate(
          [
            { opacity: 0, transform: `translate3d(${-32 - index * 12}px, ${24 + index * 8}px, 0) rotate(${-5 + index * 2}deg)` },
            { opacity: 1, transform: '' },
          ],
          { duration: 520, delay: 70 + index * 75, easing, fill: 'backwards' },
        ),
      )
      document.querySelector('[data-chain]')?.animate(
        [
          { opacity: 0, transform: 'translate3d(9%, -5%, 0) scale(0.96)' },
          { opacity: 0.95, transform: '' },
        ],
        { duration: 760, delay: 280, easing, fill: 'backwards' },
      )
      document.querySelectorAll('[data-strip]').forEach((element, index) =>
        element.animate(
          [
            { opacity: 0, transform: `translate3d(${index % 2 ? 12 : -12}%, 18px, 0) rotate(${index % 2 ? 2 : -2}deg)` },
            { opacity: 1, transform: '' },
          ],
          { duration: 440, delay: 420 + index * 90, easing, fill: 'backwards' },
        ),
      )
    }
  </script>
</Layout>
