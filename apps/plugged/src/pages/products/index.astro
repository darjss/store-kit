---
import { commerce } from "@store-kit/commerce";
import type { ProductListFilters } from "@store-kit/commerce/catalog";
import Layout from "~/layouts/Layout.astro";
import { mediaUrl } from "~/media-url";

const params = Astro.url.searchParams;
const validUseCases = ["first-iem", "bass", "vocals", "gaming", "daily-carry"] as const;
const useCaseValue = params.get("useCase");
const filters: ProductListFilters = {
  ...(params.get("category") ? { category: params.get("category")! } : {}),
  ...(params.get("brand") ? { brand: params.get("brand")! } : {}),
  ...(validUseCases.includes(useCaseValue as (typeof validUseCases)[number]) ? { useCase: useCaseValue as (typeof validUseCases)[number] } : {}),
  ...(params.get("query") ? { query: params.get("query")! } : {}),
  limit: 50,
};
const [result, categories, brands] = await Promise.all([
  commerce.catalog.listProducts(filters),
  commerce.catalog.listCategories(),
  commerce.catalog.listBrands(),
]);
if (result.status === "error") throw new Error("Catalog could not be loaded.");
const products = result.value.items;
const money = new Intl.NumberFormat("mn-MN");
const labels = { "first-iem": "Анхны IEM", bass: "Bass", vocals: "Vocals", gaming: "Gaming", "daily-carry": "Daily carry" };
const treatments = [
  "col-[1/13] grid-cols-[7fr_5fr] border-4 border-ink bg-orange",
  "col-[1/7] -rotate-1",
  "col-[8/13] mt-28",
  "col-[2/12] grid-cols-[1fr_1.1fr] border-4 border-ink bg-acid",
];
const filterClass = "shrink-0 border-3 border-ink bg-paper px-3 py-2 font-extrabold no-underline";
---

<Layout title="Бүх бараа · Plugged" description="IEM, portable DAC, cable сонгох." publicPage>
  <main id="main-content" class="min-h-screen pb-16 [background:url('/textures/paper-grain.avif')_repeat,var(--color-paper)] [background-blend-mode:multiply]">
    <header class="grid grid-cols-[1.5fr_1fr] items-end gap-12 border-b-[5px] border-ink px-[max(0.75rem,3vw)] py-[clamp(2rem,5vw,5rem)] max-md:grid-cols-1 max-md:gap-6"><div><p>PLUGGED CATALOG / {products.length} БАРАА</p><h1 class="m-0 font-display text-[clamp(4rem,11vw,6rem)] leading-[0.72] font-black tracking-[-0.02em] text-balance max-md:text-[4.5rem] max-[340px]:text-[3.8rem]">ЧАМАЙГ<br />ЮУ <em class="font-normal text-orange not-italic">ТАТДАГ</em> ВЭ?</h1></div><form action="/products" method="get" role="search"><label class="block font-black" for="catalog-search">Бараа хайх</label><div class="flex"><input class="min-h-13 w-full min-w-0 rounded-none border-3 border-ink bg-paper-clean p-3 placeholder:text-ink/75" id="catalog-search" name="query" value={params.get("query") ?? ""} placeholder="IEM, DAC, cable…" /><button class="border-3 border-ink bg-acid px-3 font-black" type="submit">ХАЙ →</button></div></form></header>
    <nav class="flex gap-3 overflow-x-auto border-b-4 border-ink bg-orange p-4" aria-label="Хэрэглээний шүүлтүүр"><a class:list={[filterClass, !filters.useCase && "bg-ink text-paper"]} href="/products">Бүгд</a>{validUseCases.map(slug => <a class:list={[filterClass, filters.useCase === slug && "bg-ink text-paper"]} href={`/products?useCase=${slug}`}>{labels[slug]}</a>)}</nav>
    <details class="border-b-4 border-ink px-[max(1rem,3vw)] py-4"><summary class="cursor-pointer font-black">Төрөл / брэндээр шүүх</summary><div class="flex flex-wrap gap-2 pt-3"><a class={filterClass} href="/products">Бүх төрөл</a>{categories.map(category => <a class:list={[filterClass, filters.category === category.slug && "bg-ink text-paper"]} href={`/products?category=${category.slug}`}>{category.name}</a>)}{brands.map(brand => <a class:list={[filterClass, filters.brand === brand.slug && "bg-ink text-paper"]} href={`/products?brand=${brand.slug}`}>{brand.name}</a>)}</div></details>
    {products.length === 0 ? <section class="px-4 py-32 text-center"><h2 class="font-display text-[5rem] leading-[0.8] text-balance">ЭНД ОДОО ЮУ Ч АЛГА.</h2><p>Хайлтаа богиносгох эсвэл шүүлтүүрээ цэвэрлэнэ үү.</p><a href="/products">Бүх бараа харах →</a></section> : <section class="grid grid-cols-12 gap-[clamp(1rem,3vw,3rem)] overflow-clip px-[max(0.75rem,3vw)] py-[clamp(2rem,5vw,5rem)] max-md:block max-md:px-3" aria-label="Барааны жагсаалт">
      {products.map((product, index) => {
        const image = product.images[0];
        const variant = product.variants[0];
        const stock = product.variants.reduce((sum, item) => sum + item.stockQuantity, 0);
        return <article class:list={["grid min-w-0 max-md:mb-6 max-md:grid-cols-[1.05fr_1fr] max-md:!transform-none max-md:[&:nth-child(4n+2)]:block max-md:[&:nth-child(4n+2)>div]:-mt-12 max-md:[&:nth-child(4n+2)>div]:w-[88%] max-md:[&:nth-child(4n+2)>div]:border-3 max-md:[&:nth-child(4n+2)>div]:border-ink max-md:[&:nth-child(4n+2)>div]:bg-orange max-md:[&:nth-child(4n+3)]:grid-cols-[0.8fr_1.2fr] max-md:[&:nth-child(4n+4)>a>img]:h-80 max-md:[&:nth-child(4n+4)>a>img]:object-cover", treatments[index % 4]]}>
          <a class="border-4 border-ink bg-paper-clean" href={`/products/${product.slug}`}>{image && <img class="h-full w-full object-contain" src={mediaUrl(image.r2Key)} alt={image.alt} width="800" height="620" loading={index < 2 ? "eager" : "lazy"} decoding="async" />}</a>
          <div class="relative p-4 max-md:p-3"><p class="mb-1 font-black uppercase">{product.useCases.map(item => labels[item]).join(" / ")}</p><h2 class="my-1 mb-4 font-body text-[clamp(1.8rem,3.7vw,3.8rem)] leading-[0.95] font-black tracking-[-0.03em] text-balance max-md:text-[2.4rem] max-[340px]:text-[2rem]"><a class="no-underline" href={`/products/${product.slug}`}>{product.name}</a></h2><p class="max-md:hidden">{product.shortDescription}</p>{variant && <><strong class="my-3 mr-2 inline-block font-body text-[clamp(1.4rem,4vw,2.5rem)] leading-[0.9] font-black tabular-nums">{money.format(variant.priceMnt)} ₮</strong>{variant.compareAtPriceMnt && <del class="font-bold max-md:hidden">{money.format(variant.compareAtPriceMnt)} ₮</del>}</>}<span class:list={["inline-block -rotate-3 border-3 border-ink bg-acid px-2 py-1 font-black max-md:m-0", stock > 0 && stock <= 3 && "bg-orange", stock === 0 && "bg-ink text-paper line-through"]}>{stock === 0 ? "ДУУССАН" : stock <= 3 ? "ЦӨӨН" : "БЭЛЭН"}</span><a class="mt-2 block bg-ink p-3 text-center font-black text-paper" href={`/products/${product.slug}`}>СОНГОХ →</a></div>
        </article>;
      })}
    </section>}
  </main>
</Layout>
