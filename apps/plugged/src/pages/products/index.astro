---
import { commerce } from "@store-kit/commerce";
import type { ProductListFilters } from "@store-kit/db/schemas";
import { formatMnt } from "@store-kit/storefront/format";
import { cn } from "@store-kit/ui/utils";
import { catalogHref } from "~/catalog-links";
import ProductImage from "~/components/ProductImage.astro";
import Layout from "~/layouts/Layout.astro";
import { toPublicImage } from "~/public-image";

const params = Astro.url.searchParams;
const validUseCases = ["first-iem", "bass", "vocals", "gaming", "daily-carry"] as const;
const useCaseValue = params.get("useCase");
const filters: ProductListFilters = {
  ...(params.get("category") ? { category: params.get("category")! } : {}),
  ...(params.get("brand") ? { brand: params.get("brand")! } : {}),
  ...(validUseCases.includes(useCaseValue as (typeof validUseCases)[number]) ? { useCase: useCaseValue as (typeof validUseCases)[number] } : {}),
  ...(params.get("query")?.trim() ? { query: params.get("query")!.trim() } : {}),
  limit: 50,
};
const [result, categories, brands] = await Promise.all([
  commerce.catalog.listProducts(filters),
  commerce.catalog.listCategories(),
  commerce.catalog.listBrands(),
]);
if (result.status === "error") throw new Error("Catalog could not be loaded.");
const products = result.value.items.map(product => ({ ...product, images: product.images.map(toPublicImage) }));
const useCaseLabels = { "first-iem": "АНХНЫ IEM", bass: "BASS", vocals: "VOCALS", gaming: "GAMING", "daily-carry": "DAILY CARRY" };
const activeFilters = [
  filters.category && { label: categories.find(item => item.slug === filters.category)?.name ?? filters.category, href: catalogHref(params, { category: undefined }) },
  filters.brand && { label: brands.find(item => item.slug === filters.brand)?.name ?? filters.brand, href: catalogHref(params, { brand: undefined }) },
  filters.query && { label: `“${filters.query}”`, href: catalogHref(params, { query: undefined }) },
  filters.useCase && { label: useCaseLabels[filters.useCase], href: catalogHref(params, { useCase: undefined }) },
].filter(Boolean) as { label: string; href: string }[];
---

<Layout title="Бүх бараа · Plugged" description="IEM болон portable DAC сонгох." publicPage>
  <main id="main-content" tabindex="-1" class="min-h-screen bg-petrol pb-24 text-paper">
    <header class="relative overflow-hidden border-b-4 border-paper-clean px-gutter py-[clamp(2rem,5vw,4.5rem)]">
      <div class="absolute inset-0 opacity-35 [background:url('/textures/paper-grain.avif')_repeat]" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-[82rem]">
        <h1 class="texture-paper clip-cut m-0 inline-block px-[clamp(1rem,3vw,2.5rem)] py-3 font-body text-[clamp(3.1rem,8vw,6rem)] leading-[0.82] font-black tracking-[-0.035em] text-ink">БҮХ БАРАА</h1>
        <p class="mt-5 mb-3 font-extrabold text-paper">PLUGGED CATALOG <span class="text-cyan">/</span> {products.length} БАРАА</p>
        <form action="/products" method="get" role="search" class="paper-stack grid grid-cols-[auto_minmax(0,1fr)_auto] text-ink max-sm:grid-cols-[1fr_auto]">
          {filters.category && <input type="hidden" name="category" value={filters.category} />}
          {filters.brand && <input type="hidden" name="brand" value={filters.brand} />}
          {filters.useCase && <input type="hidden" name="useCase" value={filters.useCase} />}
          <label class="grid min-h-15 place-items-center border-r-2 border-ink px-5 font-black max-sm:sr-only" for="catalog-search">БАРАА ХАЙХ</label>
          <input class="min-h-15 min-w-0 rounded-none border-0 bg-paper-clean px-5 text-lg font-extrabold placeholder:text-ink/70 focus-visible:outline-offset-[-4px]" id="catalog-search" name="query" value={filters.query ?? ""} placeholder="IEM, DAC, брэнд…" />
          <button class="pressable min-h-15 border-0 border-l-2 border-ink bg-ink px-7 font-black text-cyan" type="submit">ХАЙ →</button>
        </form>
      </div>
    </header>

    <section class="mx-auto max-w-[82rem] px-gutter py-4" aria-label="Каталогийн шүүлтүүр">
      <nav class="flex snap-x gap-px overflow-x-auto bg-ink p-1 [scrollbar-width:none]" aria-label="Хэрэглээгээр шүүх">
        <a class={cn("pressable min-h-12 shrink-0 snap-start px-5 py-3 font-black no-underline", !filters.useCase ? "bg-ink text-cyan shadow-[inset_0_-3px_0_var(--color-cyan)]" : "bg-paper-clean text-ink")} href={catalogHref(params, { useCase: undefined })} aria-current={!filters.useCase ? "page" : undefined}>БҮГД</a>
        {validUseCases.map(slug => <a class={cn("pressable min-h-12 shrink-0 snap-start bg-paper-clean px-5 py-3 font-black text-ink no-underline", filters.useCase === slug && "bg-ink text-cyan shadow-[inset_0_-3px_0_var(--color-cyan)]")} href={catalogHref(params, { useCase: slug })} aria-current={filters.useCase === slug ? "page" : undefined}>{useCaseLabels[slug]}</a>)}
      </nav>

      <details class="mt-3 border-2 border-cyan bg-ink" open={Boolean(filters.category || filters.brand)}>
        <summary class="pressable flex min-h-12 cursor-pointer items-center justify-between px-4 font-black text-paper">ТӨРӨЛ / БРЭНДЭЭР ШҮҮХ <span class="text-2xl text-cyan" aria-hidden="true">＋</span></summary>
        <div class="grid gap-4 border-t border-paper/30 p-4 md:grid-cols-2">
          <div><strong class="block text-cyan">ТӨРӨЛ</strong><div class="mt-2 flex flex-wrap gap-2"><a class="filter-chip" href={catalogHref(params, { category: undefined })}>БҮХ ТӨРӨЛ</a>{categories.map(category => <a class={cn("filter-chip", filters.category === category.slug && "filter-chip-active")} href={catalogHref(params, { category: category.slug })} aria-current={filters.category === category.slug ? "page" : undefined}>{category.slug === "eartips" ? "ACCESSORIES" : category.name}</a>)}</div></div>
          <div><strong class="block text-cyan">БРЭНД</strong><div class="mt-2 flex flex-wrap gap-2"><a class="filter-chip" href={catalogHref(params, { brand: undefined })}>БҮХ БРЭНД</a>{brands.map(brand => <a class={cn("filter-chip", filters.brand === brand.slug && "filter-chip-active")} href={catalogHref(params, { brand: brand.slug })} aria-current={filters.brand === brand.slug ? "page" : undefined}>{brand.name}</a>)}</div></div>
        </div>
      </details>

      {activeFilters.length > 0 && <div class="mt-3 flex flex-wrap items-center gap-2"><span class="font-bold">ИДЭВХТЭЙ:</span>{activeFilters.map(filter => <a class="border border-cyan px-3 py-1 font-bold text-paper no-underline" href={filter.href}>{filter.label} ×</a>)}<a class="ml-auto font-black text-cyan" href="/products">ЦЭВЭРЛЭХ</a></div>}
    </section>

    {products.length === 0 ? <section class="mx-auto grid min-h-[50svh] max-w-[50rem] place-content-center px-gutter text-center"><p class="text-cyan">0 ҮР ДҮН</p><h2 class="m-0 font-body text-[clamp(2.6rem,8vw,5rem)] leading-[0.9] font-black text-balance">ЭНЭ ШҮҮЛТҮҮРТ БАРАА АЛГА.</h2><p>Хайлтаа богиносгох эсвэл нэг шүүлтүүрийг арилгана уу.</p><a class="pressable mx-auto mt-4 border-2 border-cyan px-5 py-3 font-black text-paper no-underline" href="/products">БҮХ БАРАА ХАРАХ →</a></section> : <section class="mx-auto grid max-w-[82rem] gap-5 px-gutter py-6" aria-label="Барааны жагсаалт">
      {products.map((product, index) => {
        const image = product.images[0];
        const variant = product.variants[0];
        const stock = product.variants.reduce((sum, item) => sum + item.stockQuantity, 0);
        return <article data-catalog-product style={`--reveal-index:${Math.min(index, 8)}`} class={cn("group relative grid min-h-45 grid-cols-[minmax(13rem,0.9fr)_minmax(0,1.6fr)] items-stretch bg-ink max-md:min-h-0 max-md:grid-cols-1", index % 2 === 1 && "md:ml-[8%]", index % 3 === 2 && "md:mr-[5%]")}>
          <a class="relative min-h-45 overflow-hidden bg-petrol max-md:min-h-56" href={`/products/${product.slug}`} tabindex="-1">{image && <ProductImage class="absolute inset-0 h-full w-full object-contain p-2 transition-transform duration-200 ease-[var(--ease-slam)] motion-reduce:transition-none group-hover:scale-[1.025]" image={image} layout="listingHalf" priority={index === 0} />}</a>
          <div class="texture-paper relative grid grid-cols-[minmax(0,1fr)_auto_auto] items-center gap-5 p-[clamp(0.8rem,2vw,1.5rem)] text-ink max-md:-mt-2 max-md:grid-cols-[minmax(0,1fr)_auto] max-md:[clip-path:polygon(0_4%,100%_0,98%_100%,1%_96%)]">
            <div class="min-w-0"><p class="m-0 text-sm font-black text-cyan-deep">{product.brand?.name ?? "PLUGGED"}</p><h2 class="my-1 font-body text-[clamp(1.6rem,3vw,2.6rem)] leading-[0.95] font-black tracking-[-0.03em] text-balance"><a class="no-underline" href={`/products/${product.slug}`}>{product.name}</a></h2><p class="m-0 line-clamp-2 max-md:hidden">{product.shortDescription}</p></div>
            <div class="border-x-2 border-ink px-5 max-md:col-1 max-md:border-l-0 max-md:pl-0"><strong class="block text-[clamp(1.35rem,2.6vw,2rem)] leading-none font-black tabular-nums">{variant ? formatMnt(variant.priceMnt) : "—"}</strong><span class={cn("mt-2 block font-black text-cyan-deep", stock === 0 && "text-warning")}>{stock === 0 ? "ДУУССАН" : stock <= 3 ? "ЦӨӨН" : "БЭЛЭН"}</span></div>
            <a class="pressable min-h-12 self-center border-2 border-cyan-deep px-4 py-3 font-black text-cyan-deep no-underline max-md:col-2 max-md:row-2" href={`/products/${product.slug}`}>СОНГОХ →</a>
          </div>
        </article>;
      })}
    </section>}
  </main>
</Layout>
