---
import { Image } from 'astro:assets'

import { productImageLayouts } from './product-image'
import type { ProductImageLayout, ProductImageMetadata } from './product-image'

interface Props {
  image: ProductImageMetadata
  layout: ProductImageLayout
  class?: string
  priority?: boolean
}

const { image, layout, class: className, priority = false } = Astro.props
const config = productImageLayouts[layout]
---

{
  image.url.startsWith('/media/') ? (
    <img
      src={image.url}
      alt={image.alt}
      width={image.width}
      height={image.height}
      sizes={config.sizes}
      loading={priority ? 'eager' : 'lazy'}
      decoding={priority ? 'sync' : 'async'}
      fetchpriority={priority ? 'high' : 'auto'}
      class={className}
    />
  ) : (
    <Image
      src={image.url}
      alt={image.alt}
      width={image.width}
      height={image.height}
      widths={[...config.breakpoints]}
      sizes={config.sizes}
      layout="constrained"
      fit="scale-down"
      quality={80}
      priority={priority}
      class={className}
    />
  )
}
