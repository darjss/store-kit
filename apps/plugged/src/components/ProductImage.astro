---
import { Image } from '@unpic/astro/base'

import {
  productImageLayouts,
  productImageOptions,
  productImageTransformer,
} from './product-image'
import type { ProductImageLayout, ProductImageMetadata } from './product-image'

interface Props {
  image: ProductImageMetadata
  layout: ProductImageLayout
  class?: string
  priority?: boolean
}

const { image, layout, class: className, priority = false } = Astro.props
const config = productImageLayouts[layout]
---

<Image
  src={image.url}
  alt={image.alt}
  width={image.width}
  height={image.height}
  layout="constrained"
  sizes={config.sizes}
  breakpoints={[...config.breakpoints]}
  transformer={productImageTransformer(image.url)}
  options={productImageOptions(image.url)}
  operations={{ quality: 80, format: 'auto', fit: 'scale-down' }}
  priority={priority}
  unstyled
  class={className}
/>
